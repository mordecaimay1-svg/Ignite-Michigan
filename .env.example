# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Ignite Michigan

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=ignite@ignite-michigan.org

# Join form (/api/join) — HubSpot only, no Supabase required
# Private App token — server-only, never expose to the browser
HUBSPOT_ACCESS_TOKEN=
# Portal ID for tracking script (safe to expose). From embed: js-na2.hs-scripts.com/246483144.js
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=246483144

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Admin bootstrap (comma-separated emails)
ADMIN_EMAILS=admin@ignitemichigan.org
